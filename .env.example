# ── Discord credentials ──────────────────────────────────────────────
# From https://discord.com/developers/applications → your app → "Bot"
DISCORD_TOKEN=your-bot-token-here
# "General Information" → Application ID
CLIENT_ID=your-application-id-here
# Right-click your server → Copy Server ID (needs Developer Mode enabled).
# Commands register instantly to this guild. Leave blank to register globally
# (slower to propagate, ~1h).
GUILD_ID=your-server-id-here

# ── The "New Wegos" role ─────────────────────────────────────────────
# Preferred: the role ID (right-click the role → Copy Role ID).
NEW_WEGOS_ROLE_ID=
# Fallback if no ID is set: match the role by name.
NEW_WEGOS_ROLE_NAME=New Wegos

# ── Timing ───────────────────────────────────────────────────────────
# How long (in minutes) after joining before a member gets the role.
JOIN_ROLE_DELAY_MINUTES=60
# How often (in seconds) the scheduler checks for members who are due.
SWEEP_INTERVAL_SECONDS=60

# ── Assignable ranks (for /give-rank autocomplete) ───────────────────
# Comma-separated list of role names members can be granted via /give-rank.
# Leave blank to allow any role the bot can manage.
ASSIGNABLE_RANKS=New Wegos,Wego,Veteran Wego

# ── Logging ──────────────────────────────────────────────────────────
# One of: debug, info, warn, error
LOG_LEVEL=info
